# --- App ---
# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,https://secure-audit-hub.netlify.app

# --- Database ---
# Default = local SQLite file. For production, use Postgres/MySQL URL instead.
DATABASE_URL=sqlite:///./secure_audit_hub.db

# --- AI Chatbot ---
# If set, the chatbot uses real Claude AI answers.
# If left empty, it automatically falls back to the built-in rule-based ISO answers
# (same behaviour as the original frontend ChatBot.jsx) so the app still works with zero setup.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Contact form email (SMTP) ---
# If left empty, messages are still saved to the database, just not emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=63aaradhyauttekar@gmail.com
